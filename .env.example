# ==============================================
# نظام إدارة الفعاليات - ملف البيئة
# ==============================================

# ==============================================
# قاعدة البيانات (Database)
# ==============================================
# رابط الاتصال بـ MongoDB
MONGODB_URI=mongodb://localhost:27017/event-management

# ==============================================
# الأمان (Security)
# ==============================================
# مفتاح JWT - يجب تغييره في الإنتاج
# استخدم مفتاح عشوائي قوي (32+ حرف)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ==============================================
# WhatsApp Business API
# ==============================================
# رابط API الخاص بـ WhatsApp
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# Access Token من Meta for Developers
# احصل عليه من: https://developers.facebook.com/
WHATSAPP_API_TOKEN=your-whatsapp-business-api-token

# Phone Number ID من WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Verify Token للـ Webhook (اختر أي نص عشوائي)
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token-for-webhook

# ==============================================
# التطبيق (Application)
# ==============================================
# رابط التطبيق الأساسي
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# بيئة التشغيل
NODE_ENV=development

# ==============================================
# Redis (للQueue System)
# ==============================================
# رابط الاتصال بـ Redis
REDIS_URL=redis://localhost:6379

# كلمة مرور Redis (اختياري)
# REDIS_PASSWORD=your-redis-password

# ==============================================
# رفع الملفات (File Upload)
# ==============================================
# الحد الأقصى لحجم الملف (بالبايت)
# 10MB = 10485760
MAX_FILE_SIZE=10485760

# مجلد رفع الملفات
UPLOAD_DIR=./public/uploads

# ==============================================
# البريد الإلكتروني (Email) - اختياري
# ==============================================
# SMTP Server
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ==============================================
# التحليلات (Analytics) - اختياري
# ==============================================
# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ==============================================
# المراقبة (Monitoring) - اختياري
# ==============================================
# Sentry DSN
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ==============================================
# ملاحظات مهمة
# ==============================================
# 1. لا تشارك هذا الملف مع أحد
# 2. أضف .env.local إلى .gitignore
# 3. غيّر JWT_SECRET في الإنتاج
# 4. استخدم HTTPS في الإنتاج
# 5. فعّل SSL للـ MongoDB في الإنتاج
# 6. استخدم Redis مع كلمة مرور في الإنتاج

# ==============================================
# للبدء السريع
# ==============================================
# 1. انسخ هذا الملف إلى .env.local
# 2. عدّل القيم حسب بيئتك
# 3. شغّل: npm run dev
